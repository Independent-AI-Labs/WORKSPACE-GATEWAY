{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "workspace-gw-kimi-oauth": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Workspace GW (Kimi OAuth)",
      "options": {
        "baseURL": "http://localhost:9080/kimi"
      },
      "models": {
        "kimi-k2.7-code": {
          "name": "Kimi K2.7 Code",
          "limit": {
            "context": 262144,
            "output": 262144
          },
          "reasoning": true,
          "attachment": true,
          "tool_call": true,
          "cost": {
            "input": 0.95,
            "output": 4,
            "cache_read": 0.19
          }
        }
      }
    }
  }
}
