  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "datasource": {
          "uid": "clickhouse",
          "type": "grafana-clickhouse-datasource"
        },
        "query": "SELECT DISTINCT model FROM (SELECT model FROM llm_gateway.request_log WHERE model != '' UNION ALL SELECT model FROM llm_gateway.usage_log WHERE model != '') ORDER BY model",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "api_key",
        "label": "Client API Key",
        "type": "query",
        "datasource": {
          "uid": "clickhouse",
          "type": "grafana-clickhouse-datasource"
        },
        "query": "SELECT k AS __text, k AS __value FROM (SELECT DISTINCT coalesce(nullIf(key_id,''), nullIf(api_key_id,''), 'unknown') AS k FROM llm_gateway.request_log) ORDER BY k",
        "multi": true,
        "includeAll": true,
        "allValue": null,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 3,
      "title": "Token Usage by Category",
      "type": "stat",
      "datasource": {
        "uid": "clickhouse",
        "type": "grafana-clickhouse-datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "rawSql": "WITH totals AS (\n    SELECT\n        toInt64(sum(total_tokens)) as total_tok,\n        toInt64(sum(prompt_tokens - cached_tokens)) as input_tok,\n        toInt64(sum(cached_tokens)) as cached_tok,\n        toInt64(sum(completion_tokens - reasoning_tokens)) as output_tok,\n        toInt64(sum(reasoning_tokens)) as reasoning_tok,\n        sum(cost) as total_cost\n    FROM llm_gateway.usage_log\n    WHERE $__timeFilter(timestamp) AND coalesce(nullIf(key_id,''), nullIf(api_key_id,''), 'unknown') IN (${api_key:singlequote}) AND model IN (${model:singlequote})\n)\nSELECT\n    concat(multiIf(total_tok >= 1000000, concat(toString(round(total_tok / 1000000)), ' Mil'), total_tok >= 1000, concat(toString(round(total_tok / 1000)), ' K'), toString(total_tok)), ' ($', toString(toDecimal64(total_cost, 2)), ')') as Total,\n    concat(multiIf(input_tok >= 1000000, concat(toString(round(input_tok / 1000000)), ' Mil'), input_tok >= 1000, concat(toString(round(input_tok / 1000)), ' K'), toString(input_tok)), ' ($', toString(toDecimal64(if(total_tok > 0, total_cost * input_tok / total_tok, 0), 2)), ')') as Input,\n    concat(multiIf(cached_tok >= 1000000, concat(toString(round(cached_tok / 1000000)), ' Mil'), cached_tok >= 1000, concat(toString(round(cached_tok / 1000)), ' K'), toString(cached_tok)), ' ($', toString(toDecimal64(if(total_tok > 0, total_cost * cached_tok / total_tok, 0), 2)), ')') as Cached,\n    concat(multiIf(output_tok >= 1000000, concat(toString(round(output_tok / 1000000)), ' Mil'), output_tok >= 1000, concat(toString(round(output_tok / 1000)), ' K'), toString(output_tok)), ' ($', toString(toDecimal64(if(total_tok > 0, total_cost * output_tok / total_tok, 0), 2)), ')') as Output,\n    concat(multiIf(reasoning_tok >= 1000000, concat(toString(round(reasoning_tok / 1000000)), ' Mil'), reasoning_tok >= 1000, concat(toString(round(reasoning_tok / 1000)), ' K'), toString(reasoning_tok)), ' ($', toString(toDecimal64(if(total_tok > 0, total_cost * reasoning_tok / total_tok, 0), 2)), ')') as Reasoning\nFROM totals"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#247ba0"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Total"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Total"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "#70c1b3",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Input"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Input (uncached)"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "#247ba0",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Cached"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Cached"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "#8cada7",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Output"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Output (non-reasoning)"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "#ffe066",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Reasoning"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Reasoning"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "#f25f5c",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/Total|Input|Cached|Output|Reasoning/",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 15,
      "title": "Cost Over Time by Model ($)",
      "type": "timeseries",
      "datasource": {
        "uid": "clickhouse",
        "type": "grafana-clickhouse-datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "queryType": "timeseries",
          "refId": "A",
          "format": "timeseries",
          "timeColumn": "time",
          "rawSql": "SELECT toStartOfMinute(timestamp) as time, model as label, round(sum(cost), 6) as cost FROM llm_gateway.usage_log WHERE $__timeFilter(timestamp) AND coalesce(nullIf(key_id,''), nullIf(api_key_id,''), 'unknown') IN (${api_key:singlequote}) AND model IN (${model:singlequote}) GROUP BY time, model ORDER BY time, label"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "fillOpacity": 30,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 8,
      "title": "Model Distribution",
      "type": "bargauge",
      "datasource": {
        "uid": "clickhouse",
        "type": "grafana-clickhouse-datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "queryType": "table",
          "refId": "A",
          "rawSql": "SELECT model, count() as requests FROM llm_gateway.usage_log WHERE $__timeFilter(timestamp) AND model != '' AND coalesce(nullIf(key_id,''), nullIf(api_key_id,''), 'unknown') IN (${api_key:singlequote}) AND model IN (${model:singlequote}) GROUP BY model ORDER BY requests DESC LIMIT 20",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": true
        }
      }
    }
