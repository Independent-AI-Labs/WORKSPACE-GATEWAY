{
  "title": "Gateway Cost & Usage",
  "uid": "gateway-cost-usage",
  "tags": [
    "gateway",
    "llm"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "hideControls": true,
  "refresh": "5s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h",
      "2h",
