                  "fixedColor": "#ffe066",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Reasoning"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Reasoning"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "#f25f5c",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
