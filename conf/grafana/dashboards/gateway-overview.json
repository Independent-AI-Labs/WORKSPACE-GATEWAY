    {
      "id": 15,
      "title": "Cost Over Time by Model ($)",
      "type": "timeseries",
      "datasource": {
        "uid": "clickhouse",
        "type": "grafana-clickhouse-datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "queryType": "timeseries",
          "refId": "A",
          "format": "timeseries",
          "timeColumn": "time",
          "rawSql": "SELECT toStartOfMinute(timestamp) as time, model as label, round(sum(cost), 6) as cost FROM llm_gateway.usage_log WHERE $__timeFilter(timestamp) AND coalesce(nullIf(key_id,''), nullIf(api_key_id,''), 'unknown') IN (${api_key:singlequote}) AND model IN (${model:singlequote}) GROUP BY time, model ORDER BY time, label"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "fillOpacity": 30,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
