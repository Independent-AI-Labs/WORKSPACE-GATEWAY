# Required secrets
# APISIX Admin API key (Admin API, dashboard login, route seeding).
# See APISIX documentation for the default development key.
ADMIN_KEY=your-apisix-admin-key-here
OPENCODE_API_KEY=sk-your-opencode-key-here
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
GATEWAY_API_KEY=vgw-gateway-key
OPENBAO_TOKEN=your-openbao-token-here

# Optional
GRAFANA_ADMIN_PASSWORD=admin
# Grafana public URL (prod wiki proxy: https://workspaceguardrails.com/grafana/)
GRAFANA_ROOT_URL=http://localhost:3030/
# Local dev: anonymous Viewer on localhost. Prod: false; wiki nginx sends X-WEBAUTH-USER.
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_PROXY_ENABLED=false

# Context window tuning
CONTEXT_LIMIT_PCT=80
CONTEXT_LIMIT_CEILING=128000

# Llamafile local test upstream (VM-owned server, gateway only routes to it).
# The .j2 render of conf/apisix.yaml reads these; defaults below match the
# VM's llamafile systemd service (make install-llamafile MODEL=minicpm5-1b).
LLAMAFILE_UPSTREAM_HOST=host.docker.internal
LLAMAFILE_UPSTREAM_PORT=8765
